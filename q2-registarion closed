<!DOCTYPE html>
<html>
<head>
<title>Event Countdown Timer</title>
<style>
    body {
        font-family: Arial;
        padding: 30px;
        background: #eef7ff;
    }
    #countdown {
        font-size: 30px;
        font-weight: bold;
        color: #0055aa;
    }
</style>
</head>
<body>

<h2>Event Registration Countdown</h2>

<div id="countdown"></div>

<script>
let eventDate = new Date("2025-01-01 00:00:00").getTime(); // Set future event date

let timer = setInterval(function() {

    let now = new Date().getTime();
    let diff = eventDate - now;

    if (diff <= 0) {
        clearInterval(timer);
        document.getElementById("countdown").innerHTML = "Registration Closed";
        return;
    }

    // Time Calculations
    let days = Math.floor(diff / (1000 * 60 * 60 * 24));
    let hours = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
    let minutes = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
    let seconds = Math.floor((diff % (1000 * 60)) / 1000);

    document.getElementById("countdown").innerHTML =
        days + "d " + hours + "h " + minutes + "m " + seconds + "s ";
}, 1000);
</script>

</body>
</html>
